{
  // Strict source check for CI: Vite/Vite+ app surface with Bundler resolution.
  // skipLibCheck: true — third-party vendor .d.ts internals (e.g. Radix duplicate
  // index signatures) are not this gate's responsibility; those are upstream issues.
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable", "ESNext.Temporal"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": false
  },
  "include": ["src", "shared"]
}
