{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "ESNext.Temporal"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["functions/**/*.ts", "worker/**/*.ts", "cloudflare-env.d.ts"]
}
