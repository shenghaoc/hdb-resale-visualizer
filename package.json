{
  "name": "hdb-resale-visualizer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run check:data && tsc -b && vite build && npm run check:bundle",
    "build:full": "npm run sync-data && tsc -b && vite build && npm run check:bundle",
    "build:deploy": "npm run check:data && tsc -b && vite build && npm run check:bundle",
    "check:bundle": "tsx scripts/check-bundle.ts",
    "check:data": "tsx scripts/check-data-artifacts.ts",
    "check": "npm run typecheck && npm run lint && npm run test",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "ESLINT_TYPED=1 eslint . --cache --cache-location node_modules/.cache/eslint-typed --cache-strategy content",
    "lint:fast": "eslint . --cache --cache-location node_modules/.cache/eslint --cache-strategy content",
    "lint:typed": "npm run lint",
    "test": "NODE_OPTIONS=--no-experimental-webstorage vitest run",
    "test:watch": "NODE_OPTIONS=--no-experimental-webstorage vitest",
    "test:e2e": "playwright test",
    "sync-data": "tsx scripts/sync-data.ts"
  },
  "dependencies": {
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "lucide-react": "^1.14.0",
    "maplibre-gl": "^5.24.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.6.0",
    "temporal-polyfill": "^0.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.7.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-check": "^4.8.0",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "papaparse": "^5.5.3",
    "shadcn": "^4.6.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6",
    "wrangler": "^4.90.1",
    "zod": "^4.4.1"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "packageManager": "npm@11.14.0"
}
