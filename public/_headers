/*
  # Prevent MIME-type sniffing attacks
  X-Content-Type-Options: nosniff
  # Prevent clickjacking by blocking cross-origin framing
  X-Frame-Options: SAMEORIGIN
  # Modern clickjacking protection and automatic HTTPS upgrades
  Content-Security-Policy: frame-ancestors 'self'; upgrade-insecure-requests; object-src 'none'; base-uri 'self';
  # Force HTTPS for a year, including subdomains
  Strict-Transport-Security: max-age=31536000; includeSubDomains;
  # Prevent filter state / coordinates in URL params from leaking to external origins (OneMap, Google Maps)
  Referrer-Policy: strict-origin-when-cross-origin
  # Restrict browser features the app does not use, allowing geolocation for 'near me'
  Permissions-Policy: camera=(), microphone=(), geolocation=(self)
