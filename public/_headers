/*
# Prevent MIME-type sniffing attacks
  X-Content-Type-Options: nosniff
# Prevent clickjacking by blocking cross-origin framing
  X-Frame-Options: SAMEORIGIN
# Modern clickjacking protection, automatic HTTPS upgrades, and resource rules
  Content-Security-Policy: default-src 'self'; script-src 'self'; connect-src 'self' https://*.onemap.gov.sg https://*.onemap.sg https://demotiles.maplibre.org https://fonts.openmaptiles.org; img-src 'self' data: blob: https://*.onemap.gov.sg https://*.onemap.sg https://demotiles.maplibre.org; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:; frame-ancestors 'self'; upgrade-insecure-requests; object-src 'none'; base-uri 'self';
# Force HTTPS for a year, including subdomains
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
# Prevent filter state / coordinates in URL params from leaking to external origins
  Referrer-Policy: strict-origin-when-cross-origin
# Restrict browser features the app does not use, allowing geolocation for 'near me'
  Permissions-Policy: camera=(), microphone=(), geolocation=(self)
